{
  "manifest_version": 3,
  "name": "EasyRead \u2014 Read Aloud",
  "version": "2.0.0",
  "description": "Speed-read any selected text or article: flashes one magnified word at a time at your chosen WPM, with a fixed focus point. No audio, no account, no tracking.",
  "permissions": [
    "contextMenus",
    "scripting",
    "storage",
    "activeTab"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "EasyRead \u2014 Read Aloud",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "commands": {
    "read-aloud": {
      "suggested_key": {
        "default": "Alt+R"
      },
      "description": "Speed-read selection (or page)"
    }
  }
}
